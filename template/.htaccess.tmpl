# Pass Authorization header through to PHP on CGI/FastCGI hosting
# Without this, shared hosts that run PHP as CGI strip the Authorization header
# that Magnitu sends as `Authorization: Bearer <api_key>`.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP:Authorization} .+
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

<IfModule mod_setenvif.c>
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# Satellite {{SLUG}} — generated by seismo-generator.
# Hardening: block direct access to config.local.php and build artefacts.
<FilesMatch "(config\.local\.php|satellite\.json|\.sql)$">
    Require all denied
</FilesMatch>
